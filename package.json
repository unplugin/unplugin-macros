{
  "name": "unplugin-macros",
  "type": "module",
  "version": "0.20.2",
  "packageManager": "pnpm@11.9.0",
  "description": "Macros for bundlers.",
  "author": "Kevin Deng <sxzz@sxzz.moe>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/sxzz",
  "homepage": "https://github.com/unplugin/unplugin-macros#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unplugin/unplugin-macros.git"
  },
  "bugs": {
    "url": "https://github.com/unplugin/unplugin-macros/issues"
  },
  "keywords": [
    "unplugin",
    "rollup",
    "vite",
    "esbuild",
    "webpack"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./api": "./dist/api.mjs",
    "./esbuild": "./dist/esbuild.mjs",
    "./rolldown": "./dist/rolldown.mjs",
    "./rollup": "./dist/rollup.mjs",
    "./rspack": "./dist/rspack.mjs",
    "./vite": "./dist/vite.mjs",
    "./webpack": "./dist/webpack.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "pnpm run lint --fix",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsgo --noEmit",
    "format": "prettier --cache --write .",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@babel/types": "^8.0.0",
    "ast-kit": "^3.0.0",
    "magic-string-ast": "^2.0.0",
    "rolldown-string": "^0.3.0",
    "unplugin": "^3.0.0",
    "vite": "^8.0.12",
    "vite-node": "^6.0.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^8.0.0",
    "@sxzz/eslint-config": "^8.2.1",
    "@sxzz/prettier-config": "^2.3.1",
    "@sxzz/test-utils": "^0.5.18",
    "@types/dedent": "^0.7.2",
    "@types/node": "^25.9.3",
    "@typescript/native-preview": "7.0.0-dev.20260629.1",
    "bumpp": "^11.1.0",
    "dedent": "^1.7.2",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "rollup": "^4.62.0",
    "tsdown": "^0.22.2",
    "tsdown-preset-sxzz": "^0.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.38"
  },
  "prettier": "@sxzz/prettier-config"
}
